{% extends 'layout.html.twig' %}
{% block title %}Détails de livres{% endblock %}
{% block content %}
<div class="min-h-screen py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
        
        {# Header de la page #}
        <div class="flex justify-between items-center mb-10 border-b border-gray-200 pb-6">
            <div>
                <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
                    <span class="text-indigo-600 italic">Livres</span>
                </h1>
                <p class="mt-2 text-sm text-gray-500 uppercase tracking-widest">Détails du livre</p>
            </div>
        </div>

        {# Contenu #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
            <div class="px-4 py-5 sm:px-6 bg-indigo-50">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Informations du livre</h3>
            </div>
            <div class="border-t border-gray-200">
                <dl>
                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">ID</dt>
                        <dd class="mt-1 text-sm text-indigo-600 sm:mt-0 sm:col-span-2 font-mono">
                            {{ book.id }}
                        </dd>
                    </div>

                    <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Titre</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-bold sm:mt-0 sm:col-span-2">
                            {{ book.title }}
                        </dd>
                    </div>

                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Auteur</dt>
                        <dd class="mt-1 text-sm text-indigo-700 sm:mt-0 sm:col-span-2 font-semibold">
                            {{ book.author.name }}
                        </dd>
                    </div>

                    <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Résumé</dt>
                        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 leading-relaxed">
                            {{ book.description }}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

    </di>
    <div class="mt-6">
        <a href="{{ path('app_book_index') }}" class="text-indigo-600 hover:text-indigo-900 font-bold underline">
            Retour à la liste
        </a>
    </div>
</div>
{% endblock %}