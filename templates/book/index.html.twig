{% extends 'layout.html.twig' %}
{% block title %}Mes Livres{% endblock %}
{% block content %}
<div class="min-h-screen py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
        
        {# Header de la page #}
        <div class="flex justify-between items-center mb-10 border-b border-gray-200 pb-6">
            <div>
                <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
                    <span class="text-indigo-600 italic">Livres</span>
                </h1>
                <p class="mt-2 text-sm text-gray-500 uppercase tracking-widest">Liste de livres !</p>
            </div>
            <div class="bg-indigo-600 text-white px-4 py-2 rounded-lg font-bold shadow-lg">
                {{ books|length }} Livres
            </div>
        </div>

        {# Liste de Livres #}
        <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
            <table class="w-full border-collapse text-left">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="px-8 py-5 text-sm font-bold uppercase tracking-wider">Titre</th>
                        <th class="px-8 py-5 text-sm font-bold uppercase tracking-wider text-right">Auteur</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for book in books %}
                    <tr class="hover:bg-indigo-50/50 transition-all duration-200 group">
                        <td class="px-8 py-6">
                            <div class="flex items-center">
                                <div class="h-10 w-10 flex-shrink-0 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center font-bold mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                                    {{ loop.index }}
                                </div>
                                <a href="{{ path('app_book_fiche', {'id': book.id}) }}" class="text-lg font-semibold text-gray-900 hover:text-indigo-600 transition-colors">
                                    {{ book.title }}
                                </a>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-right">
                            <span class="inline-block px-4 py-2 rounded-lg bg-indigo-50 text-indigo-700 font-medium border border-indigo-100 shadow-sm">
                                {{ book.author.name }}
                            </span>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="2" class="px-8 py-16 text-center">
                            <div class="flex flex-col items-center">
                                <svg class="w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <p class="text-xl font-medium text-gray-400 font-italic">Rien à voir pour l'instant !</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}