{% extends 'base.html.twig' %}
{% block title %}Détail du marque page{% endblock %}
{% block body %}
<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
        
        {# Header de la page #}
        <div class="flex justify-between items-center mb-10 border-b border-gray-200 pb-6">
            <div>
                <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
                    <span class="text-indigo-600 italic">Bookmark</span>
                </h1>
                <p class="mt-2 text-sm text-gray-500 uppercase tracking-widest">Détails du bookmark</p>
            </div>
        </div>

        {# Contenu #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
            <div class="px-4 py-5 sm:px-6 bg-indigo-50">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Information du lien</h3>
            </div>
            <div class="border-t border-gray-200">
                <dl>
                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">ID</dt>
                        <dd class="mt-1 text-sm text-indigo-600 sm:mt-0 sm:col-span-2 font-mono">
                            {{ bookmark.id }}
                        </dd>
                    </div>
                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">URL</dt>
                        <dd class="mt-1 text-sm text-indigo-600 sm:mt-0 sm:col-span-2 font-mono">
                            {{ bookmark.url }}
                        </dd>
                    </div>
                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Date d'ajout</dt>
                        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                            {{ bookmark.dateCreation|date('d/m/Y à H:i') }}
                        </dd>
                    </div>
                    <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Commentaire</dt>
                        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 italic">
                            {{ bookmark.commentaire }}
                        </dd>
                    </div>
                    <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Mots-clés</dt>
                        <dd class="flex flex-col space-y-2 items-start mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                            {% for keyword in bookmark.keywords %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 mr-2">
                                    #{{ keyword.name }}
                                </span>
                            {% else %}
                                <span class="text-gray-400 italic">Aucun mot-clé</span>
                            {% endfor %}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        <div class="mt-6">
            <a href="{{ path('app_bookmark_index') }}" class="text-indigo-600 hover:text-indigo-900 font-bold underline">
                Retour à la liste
            </a>
        </div>

        {# Footer d'informations #}
        <p class="mt-8 text-center text-xs text-gray-400 uppercase tracking-tighter">
            Projet Avengers - Symfony 7 & Tailwind CSS - {{ "now"|date("Y") }}
        </p>
    </div>
</div>
{% endblock %}