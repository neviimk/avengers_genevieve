{% extends 'layout.html.twig' %}

{% block title %}Accueil - Symfony dans tous ses états !{% endblock %}

{% block content %}
<div class="py-12">
    <div class="text-center">
        <h1 class="text-5xl font-extrabold text-gray-900 mb-6">
            Bienvenue sur <span class="text-indigo-600">Avengers</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Découvrez mes rubriques Symfony : Bookmarks, Books et Cailloux!
        </p>
    </div>

    {# Cartes de navigation #}
    <div class="m-16 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition">
            <h2 class="text-2xl font-bold text-indigo-600 mb-4">★ Bookmarks</h2>
            <p class="text-gray-500 mb-6">Gestion de ressources web utiles.</p>
            <a href="{{ path('app_bookmark_index') }}" class="text-indigo-600 font-semibold no-underline">Voir la liste</a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition">
            <h2 class="text-2xl font-bold text-indigo-600 mb-4">★ Books</h2>
            <p class="text-gray-500 mb-6">Gestion de livres.</p>
            <a href="{{ path('app_book_index') }}" class="text-indigo-600 font-semibold no-underline">Voir la liste</a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition">
            <h2 class="text-2xl font-bold text-indigo-600 mb-4">★ Cailloux</h2>
            <p class="text-gray-500 mb-6">Gestion de la faune/flore du pays.</p>
            <a href="{{ path('app_cailloux_faune') }}" class="text-indigo-600 font-semibold no-underline">Voir la liste</a>
        </div>
    </div>
</div>
{% endblock %}