                    <span class="text-indigo-700 font-semibold italic">Symfony dans tous ses états !</span>
                </div>

                <div id="collapseMenu"
                class="max-lg:hidden lg:!block max-lg:before:fixed max-lg:before:bg-black max-lg:before:opacity-50 max-lg:before:inset-0 max-lg:before:z-50">
                <button id="toggleClose" class="lg:hidden fixed top-2 right-4 z-[100] rounded-full bg-white w-9 h-9 flex items-center justify-center border border-gray-200 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 fill-black" viewBox="0 0 320.591 320.591">
                    <path
                        d="M30.391 318.583a30.37 30.37 0 0 1-21.56-7.288c-11.774-11.844-11.774-30.973 0-42.817L266.643 10.665c12.246-11.459 31.462-10.822 42.921 1.424 10.362 11.074 10.966 28.095 1.414 39.875L51.647 311.295a30.366 30.366 0 0 1-21.256 7.288z"
                        data-original="#000000"></path>
                    <path
                        d="M287.9 318.583a30.37 30.37 0 0 1-21.257-8.806L8.83 51.963C-2.078 39.225-.595 20.055 12.143 9.146c11.369-9.736 28.136-9.736 39.504 0l259.331 257.813c12.243 11.462 12.876 30.679 1.414 42.922-.456.487-.927.958-1.414 1.414a30.368 30.368 0 0 1-23.078 7.288z"
                        data-original="#000000"></path>
                    </svg>
                </button>

                    <div id="collapseMenu" class="max-lg:hidden lg:!block">
                        <ul class="lg:flex gap-x-4 max-lg:space-y-3">
                            <li class="px-3">
                                <a href="{{ path('app_home_') }}" class="hover:text-indigo-700 text-slate-900 block font-medium text-[15px]">Home</a>
                            </li>
                            <li class="px-3">
                                <a href="{{ path('app_bookmark_index') }}" class="hover:text-indigo-700 text-slate-900 block font-medium text-[15px]">Bookmarks</a>
                            </li>
                            <li class="px-3">
                                <a href="{{ path('app_book_index') }}" class="hover:text-indigo-700 text-slate-900 block font-medium text-[15px]">Books</a>
                            </li>
                            <li class="px-3 group relative">
                                <span class="cursor-pointer hover:text-indigo-700 text-slate-900 font-medium text-[15px]">Cailloux</span>
                                <ul class="absolute hidden group-hover:block bg-white shadow-lg p-2 rounded-md min-w-[120px]">
                                    <li><a href="{{ path('app_cailloux_faune') }}" class="hover:text-indigo-700 block p-2">Faune</a></li>
                                    <li><a href="{{ path('app_cailloux_flore') }}" class="hover:text-indigo-700 block p-2">Flore</a></li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        {# Contenu #}
        <main class="flex-grow">
            {% block content %}{% endblock %}
        </main>

        {# Footer #}
        <footer class="border-t py-8">
            <p class="mt-8 text-center text-xs text-gray-400 uppercase tracking-tighter">
                Projet Avengers de Genevieve Mekenese - Symfony 7 & Tailwind CSS - {{ "now"|date("Y") }}
            </p>
        </footer>
    </div>
{% endblock %}